#include <bits/stdc++.h>
using namespace std;

int main(){
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    int n, m=INT_MAX, l=-1, d=INT_MAX; cin >> n;
    vector<int> a(n);
    for (int i=0; i<n; i++){
      cin >> a[i];
      m=min(m, a[i]);
    }
    for (int i=0; i<n; i++){
      if (a[i]==m){
        if (l!=-1)
          d=min(d, i-1);
        l=i;
      }
    }
    cout << d;
}
